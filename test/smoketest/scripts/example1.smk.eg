# Create two tests for this script, one with dash content and one with hls
SET_ITERATIONS(2) Dash HLS
SET_VAR_TAGS(TUNE_URL) DASH_URL HLS_URL

# Fail the script if we ever get and error or blocked state
failon ERROR BLOCKED

#loop 10 times tune, play for 10 seconds then stop

loopstart 10

tune $TUNE_URL
waitfor 1 TUNED PLAYING
sleep 10
stop
sleep 1

loopend

